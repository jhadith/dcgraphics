<script>
  document.addEventListener('DOMContentLoaded', function () {
    AOS.init({
     duration: 2500,   // duración del efecto (ms)
      easing: 'ease',   // curva
      once: false,      // 👈 importante: que SE REPITA al volver a entrar al viewport
      offset: 80        // empieza un poco antes de entrar a pantalla
    });

    // Con Elementor, tras cargar todo refrescamos por si hay lazy-load/imágenes
    window.addEventListener('load', () => AOS.refresh());
  });
</script>

